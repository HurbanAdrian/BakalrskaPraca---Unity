        freeze: 0
        kill: 0
        debuff: 0
      curseBoosts: 0
      levelBoosts: 0
    timeLimit: 1200
    clockSpeed: 1
    extraNotes: Each red petal is a life cut short.
  - scene: {fileID: 102900000, guid: 6ee92544a5007ff49821d8d500442c14, type: 3}
    sceneName: Level 2 - Blighted Canyons
    displayName: Blighted Canyons
    label: Level 2
    description: A jagged labyrinth of ancient stone and yawning chasms. Long ago
      abandoned by life, only relentless enemies stalk these blistering, narrow passes
      to ensure no wanderer escapes alive.
    icon: {fileID: -6796711543283860128, guid: c1be849848795dd4aa7c3eed83b2b266, type: 3}
